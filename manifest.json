{
  "manifest_version": 3,
  "name": "Datasurf Extender",
  "version": "1.2.3",
  "description": "Filtro CER, consultazione rapida codici e ricerca soggetti per IoRecupero.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.datasurf.it/*"
      ],
      "js": [
        "pericolosi_cer.js",
        "catalogo_cer.js",
        "features/cer_filter.js",
        "features/soggetti_lookup.js",
        "content_script.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
