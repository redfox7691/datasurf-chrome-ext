{
  "manifest_version": 3,
  "name": "Datasurf CER Filter",
  "version": "1.0.0",
  "description": "Aggiunge il filtro Pericoloso / Non Pericoloso / Tutti all'anagrafica rifiuti di Datasurf.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://app.datasurf.it/*"],
      "js": [
        "pericolosi_cer.js",
        "features/cer_filter.js",
        "content_script.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
